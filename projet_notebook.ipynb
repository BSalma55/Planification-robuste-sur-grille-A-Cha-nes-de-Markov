[33m\"\u001b[39m,\n\u001b[32m    230\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m            current_f, _, current = heapq.heappop(open_set)\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    231\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m            open_set_lookup.remove(current)\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    232\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m            \u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    233\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m            if current == goal:\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    234\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m                path = self.reconstruct_path(came_from, current)\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    235\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m                return \u001b[39m\u001b[33m{\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    236\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m                    \u001b[39m\u001b[33m'\u001b[39m\u001b[33mpath\u001b[39m\u001b[33m'\u001b[39m\u001b[33m: path,\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    237\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m                    \u001b[39m\u001b[33m'\u001b[39m\u001b[33mcost\u001b[39m\u001b[33m'\u001b[39m\u001b[33m: g_score[current],\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    238\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m                    \u001b[39m\u001b[33m'\u001b[39m\u001b[33mnodes_expanded\u001b[39m\u001b[33m'\u001b[39m\u001b[33m: nodes_expanded,\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    239\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m                    \u001b[39m\u001b[33m'\u001b[39m\u001b[33mmax_open_size\u001b[39m\u0