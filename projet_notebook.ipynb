    "    \n",
    "    def neighbors(self, x, y):\n",
    "        \"\"\"Retourne les voisins accessibles (4-connexité).\"\"\"\n",
    "        return [(nx, ny) for nx, ny in [(x+1,y), (x-1,y), (x,y+1), (x,y-1)]\n",
    "                if self.is_free(nx, ny)]\n",
    "    \n",
    "    def manhattan(self, pos1, pos2):\n",
    "        \"\"\"Heuristique Manhattan : |x1-x2| + |y1-y2|.\"\"\"\n",
    "        return abs(pos1[0] - pos2[0]) + abs(pos1[1] - pos2[1])\n",
    "    \n",
    "    def zero(self, pos1, pos2):\n",
    "        \"\"\"Heuristique nulle (h=0).\"\"\"\n",
    "        return 0\n",
    "\n",
    "# %%\n",
    "class AStar:\n",
    "    \"\"\"\n",
    "    Recherche heuristique unifiée.\n",
    "    Formule générale : f(n) = wg * g(n) + wh * h(n)\n",
    "    \n",
    "    Algorithmes :\n",
    "    - UCS      : wg=1.0, wh=0.0\n",
    "    - Greedy   : wg=0.0, wh=1.0\n",
    "    - A*       : wg=1.0, wh=1.0\n",
    "    - Weighted : wg=1.0, wh=w (w>1)\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, grid, heuristic='manhattan'):\n",
    "        self.grid = grid\n",
    "        if heuristic == 'manhattan':\n",
    "            self.h = grid.manhattan\n",
    "        elif heuristic == 'zero':\n",
    "            self.h = grid.zero\n",
    "        else:\n",
    "            raise ValueError(f\"Heuristique inconnue: {heuristic}\")\n",
    "    \n",
    "    def search(self, start, goal, algorithm='astar', weight=1.0):\n",
    "        \"\"\"\n",
    "        Recherche du chemin de start à goal.\n",
    "        \n",
    "        Retourne un dictionnaire avec :\n",
    "        - path, cost, nodes_expanded, max_open_size, time_sec, success\n",
    "        \"\"\"\n",
    "        # Poids selon l'algorithme\n",
    "        if algorithm == 'ucs':\n",
    "            wg, wh = 1.0, 0.0\n",
    "        elif algorithm == 'greedy':\n",
    "            wg, wh = 0.0, 1.0\n",
    "        else:  # astar ou weighted\n",
    "            wg, wh = 1.0, float(weight)\n",
    "        \n",
    "        t0 = time.perf_counter()\n",
    "        \n",
    "        # Structures de données\n",
    "        counter = 0\n",
    "        open_heap = [(0.0, counter, start)]\n",
    "        in_open = {start}\n",
    "        closed = set()\n",
    "        came_from = {}\n",
    "        g_score = {start: 0}\n",
    "        \n",
    "        nodes_expanded = 0\n",
    "        max_open_size = 0\n",
    "        \n",
    "        while open_heap:\n",
    "            max_open_size = max(max_open_size, len(open_heap))\n",
    "            \n",
    "            _, _, current = heapq.heappop(open_heap)\n",
    "            in_open.discard(current)\n",
    "            \n",
    "            if current == goal:\n",
    "                return {\n",
    "                    'path': self._reconstruct(came_from, current),\n",
    "                    'cost': g_score[current],\n",
    "                    'nodes_expanded': nodes_expanded,\n",
    "                    'max_open_size': max_open_size,\n",
    "                    'time_sec': time.perf_counter() - t0,\n",
    "                    'success': True\n",
    "                }\n",
    "            \n",
    "            if current in closed:\n",
    "                continue\n",
    "            closed.add(current)\n",
    "            nodes_expanded += 1\n",
    "            \n",
    "            for nbr in self.grid.neighbors(*current):\n",
    "                if nbr in closed:\n",
    "                    continue\n",
    "                g_new = g_score[current] + 1\n",
    "                if g_new < g_score.get(nbr, float('inf')):\n",
    "                    came_from[nbr] = current\n",
    "                    g_score[nbr] = g_new\n",
    "                    f_new = wg * g_new + wh * self.h(nbr, goal)\n",
    "                    counter += 1\n",
    "                    heapq.heappush(open_heap, (f_new, counter, nbr))\n",
    "                    in_open.add(nbr)\n",
    "        \n",
    "        return {\n",
    "            'path': None,\n",
    "            'cost': float('inf'),\n",
    "            'nodes_expanded': nodes_expanded,\n",
    "            'max_open_size': max_open_size,\n",
    "            'time_sec': time.perf_counter() - t0,\n",
    "            'success': False\n",
    "        }\n",
    "    \n",
    "    def _reconstruct(self, came_from, node):\n",
    "        \"\"\"Reconstruit le chemin depuis came_from.\"\"\"\n",
    "        path = [node]\n",
    "        while node in came_from:\n",
    "            node = came_from[node]\n",
    "            path.append(node)\n",
    "        path.reverse()\n",
    "        return path\n",
    "    \n",
    "    def extract_policy(self, path):\n",
    "        \"\"\"\n",
    "        Extrait la politique (état -> action) du chemin A*.\n",
    "        Utilisé pour construire la chaîne de Markov.\n",
    "        \"\"\"\n",
    "        policy = {}\n",
    "        for i in range(len(path) - 1):\n",
    "            policy[path[i]] = (path[i+1][0] - path[i][0],\n",
    "                               path[i+1][1] - path[i][1])\n",
    "        if path:\n",
    "            policy[path[-1]] = (0, 0)  # État but : auto-boucle\n",
    "        return policy\n",
    "\n",
    "# %% [markdown]\n",
    "# # PARTIE 2 : CHAÎNE DE MARKOV\n",
    "\n",
    "# %%\n",
    "class MarkovChain:\n",
    "    \"\"\"\n",
    "    Chaîne de Markov à temps discret.\n",
    "    \n",
    "    Évolution : π(n) = π(0) * P^n\n",
    "    États absorbants : GOAL (succès) et FAIL (échec)\n",
    "    \n",
    "    Analyse d'absorption :\n",
    "    - Matrice fondamentale N = (I - Q)^-1\n",
    "    - Probabilités d'absorption B = N * R\n",
    "    - Temps moyen avant absorption t = N * 1\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, states, absorbing_states=None):\n",
    "        self.states = list(states)\n",
    "        self.n = len(self.states)\n",
    "        self.state_to_idx = {s: i for i, s in enumerate(self.states)}\n",
    "        self.idx_to_state = {i: s for i, s in enumerate(self.states)}\n",
    "        self.P = np.zeros((self.n, self.n))\n",
    "        self.absorbing_states = dict(absorbing_states) if absorbing_states else {}\n",
    "        self.absorbing_indices = {\n",
    "            self.state_to_idx[s] for s in self.absorbing_states\n",
    "            if s in self.state_to_idx\n",
    "        }\n",
    "    \n",
    "    def build_from_policy(self, policy, grid, epsilon):\n",
    "        \"\"\"\n",
    "        Construit P selon le modèle d'incertitude :\n",
    "        - Action voulue : probabilité 1-ε\n",
    "        - Déviations latérales : probabilité ε/2 chacune\n",
    "        - Si destination bloquée → self-loop\n",
    "        \"\"\"\n",
    "        valid = set(self.states)\n",
    "        \n",
    "        for state in self.states:\n",
    "            i = self.state_to_idx[state]\n",
    "            \n",
    "            # État absorbant\n",
    "            if state in self.absorbing_states:\n",
    "                self.P[i, i] = 1.0\n",
    "                continue\n",
    "            \n",
    "            # Action recommandée\n",
    "            action = policy.get(state, (0, 0))\n",
    "            dx, dy = action\n",
    "            \n",
    "            # Destination principale\n",
    "            dest_main = (state[0] + dx, state[1] + dy)\n",
    "            if not grid.is_free(*dest_main) or dest_main not in valid:\n",
    "                dest_main = state\n",
    "            self._add(i, dest_main, 1.0 - epsilon)\n",
    "            \n",
    "            # Déviations latérales\n",
    "            if action != (0, 0):\n",
    "                laterals = [(0,1), (0,-1)] if dx != 0 else [(1,0), (-1,0)]\n",
    "                for ldx, ldy in laterals:\n",
    "                    dest_lat = (state[0] + ldx, state[1] + ldy)\n",
    "                    if not grid.is_free(*dest_lat) or dest_lat not in valid:\n",
    "                        dest_lat = state\n",
    "                    self._add(i, dest_lat, epsilon / 2.0)\n",
    "        \n",
    "        self._normalize()\n",
    "    \n",
    "    def _add(self, i, dest, prob):\n",
    "        \"\"\"Ajoute une probabilité de transition.\"\"\"\n",
    "        j = self.state_to_idx.get(dest)\n",
    "        if j is not None:\n",
    "            self.P[i, j] += prob\n",
    "    \n",
    "    def _normalize(self):\n",
    "        \"\"\"Normalise les lignes pour garantir la stochasticité.\"\"\"\n",
    "        row_sums = self.P.sum(axis=1, keepdims=True)\n",
    "        row_sums[row_sums == 0] = 1.0\n",
    "        self.P /= row_sums\n",
    "    \n",
    "    def is_stochastic(self, tol=1e-9):\n",
    "        \"\"\"Vérifie que P est stochastique.\"\"\"\n",
    "        return bool(np.allclose(self.P.sum(axis=1), 1.0, atol=tol))\n",
    "    \n",
    "    def get_distribution_evolution(self, initial_state, max_steps):\n",
    "        \"\"\"\n",
    "        Calcule π(1), π(2), ..., π(max_steps).\n",
    "        \"\"\"\n",
    "        if initial_state not in self.state_to_idx:\n",
    "            raise ValueError(f\"État inconnu: {initial_state}\")\n",
    "        \n",
    "        i0 = self.state_to_idx[initial_state]\n",
    "        pi = np.zeros(self.n)\n",
    "        pi[i0] = 1.0\n",
    "        evol = []\n",
    "        \n",
    "        for _ in range(max_steps):\n",
    "            pi = pi @ self.P\n",
    "            evol.append(pi.copy())\n",
    "        \n",
    "        return evol\n",
    "    \n",
    "    def analyze_classes(self):\n",
    "        \"\"\"\n",
    "        Identifie les classes de communication via les CFC.\n",
    "        \"\"\"\n",
    "        G = nx.DiGraph()\n",
    "        G.add_nodes_from(range(self.n))\n",
    "        for i in range(self.n):\n",
    "            for j in range(self.n):\n",
    "                if self.P[i, j] > 1e-12:\n",
    "                    G.add_edge(i, j)\n",
    "        \n",
    "        classes = []\n",
    "        for comp in nx.strongly_connected_components(G):\n",
    "            # Vérifie si la classe est fermée\n",
    "            is_closed = all(\n",
    "                j in comp for i in comp for j in range(self.n)\n",
    "                if self.P[i, j] > 1e-12\n",
    "            )\n",
    "            \n",
    "            if is_closed and len(comp) == 1:\n",
    "                idx = next(iter(comp))\n",
    "                ctype = 'absorbant' if np.isclose(self.P[idx, idx], 1.0) else 'transitoire'\n",
    "            elif is_closed:\n",
    "                ctype = 'absorbant'\n",
    "            else:\n",
    "                ctype = 'transitoire'\n",
    "            \n",
    "            classes.append({\n",
    "                'etats': [self.idx_to_state[i] for i in comp],\n",
    "                'indices': list(comp),\n",
    "                'type': ctype\n",
    "            })\n",
    "        \n",
    "        return classes\n",
    "    \n",
    "    def absorption_analysis(self):\n",
    "        \"\"\"\n",
    "        Analyse d'absorption : N, B, t.\n",
    "        \"\"\"\n",
    "        if not self.absorbing_indices:\n",
    "            return None\n",
    "        \n",
    "        trans_idx = [i for i in range(self.n) if i not in self.absorbing_indices]\n",
    "        abs_idx = sorted(self.absorbing_indices)\n",
    "        \n",
    "        if not trans_idx:\n",
    "            return None\n",
    "        \n",
    "        Q = self.P[np.ix_(trans_idx, trans_idx)]\n",
    "        R = self.P[np.ix_(trans_idx, abs_idx)]\n",
    "        \n",
    "        try:\n",
    "            N = np.linalg.inv(np.eye(len(trans_idx)) - Q)\n",
    "            B = N @ R\n",
    "            t = N @ np.ones(len(trans_idx))\n",
    "            return {\n",
    "                'B': B,\n",
    "                't': t,\n",
    "                'N': N,\n",
    "                'trans_indices': trans_idx,\n",
    "                'abs_indices': abs_idx\n",
    "            }\n",
    "        except np.linalg.LinAlgError:\n",
    "            return None\n",
    "    \n",
    "    def analyze_periodicity(self):\n",
    "        \"\"\"\n",
    "        Analyse la périodicité de chaque classe.\n",
    "        \"\"\"\n",
    "        classes = self.analyze_classes()\n",
    "        results = []\n",
    "        \n",
    "        for cls in classes:\n",
    "            if cls['type'] == 'absorbant':\n",
    "                periode = 1\n",
    "            else:\n",
    "                i = cls['indices'][0]\n",
    "                Pk = self.P.copy()\n",
    "                periode = None\n",
    "                for k in range(1, min(2 * self.n + 1, 100)):\n",
    "                    if Pk[i, i] > 1e-10:\n",
    "                        periode = k\n",
    "                        break\n",
    "                    Pk = Pk @ self.P\n",
    "                periode = periode if periode is not None else 0\n",
    "            \n",
    "            results.append({\n",
    "                'etats': cls['etats'],\n",
    "                'type': cls['type'],\n",
    "                'periode': periode,\n",
    "                'est_periodique': periode > 1\n",
    "            })\n",
    "        \n",
    "        return results\n",
    "\n",
    "# %% [markdown]\n",
    "# # PARTIE 3 : SIMULATION MONTE-CARLO\n",
    "\n",
    "# %%\n",
    "class MarkovSimulation:\n",
    "    \"\"\"\n",
    "    Simulation Monte-Carlo de la chaîne de Markov.\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, markov_chain):\n",
    "        self.mc = markov_chain\n",
    "    \n",
    "    def simulate_trajectory(self, start_state, max_steps=200):\n",
    "        \"\"\"\n",
    "        Simule une trajectoire depuis start_state.\n",
    "        \"\"\"\n",
    "        if start_state not in self.mc.state_to_idx:\n",
    "            return None, None, None\n",
    "        \n",
    "        trajectory = [start_state]\n",
    "        current_idx = self.mc.state_to_idx[start_state]\n",
    "        \n",
    "        for step in range(max_steps):\n",
    "            next_idx = np.random.choice(self.mc.n, p=self.mc.P[current_idx])\n",
    "            next_state = self.mc.idx_to_state[next_idx]\n",
    "            trajectory.append(next_state)\n",
    "            \n",
    "            if next_state in self.mc.absorbing_states:\n",
    "                return trajectory, step + 1, next_state\n",
    "            \n",
    "            current_idx = next_idx\n",
    "        \n",
    "        return trajectory, max_steps, trajectory[-1]\n",
    "    \n",
    "    def run_simulations(self, start_state, n_simulations=1000, max_steps=200):\n",
    "        \"\"\"\n",
    "        Lance N simulations et collecte les statistiques.\n",
    "        \"\"\"\n",
    "        stats = {\n",
    "            'goal_count': 0,\n",
    "            'fail_count': 0,\n",
    "            'other_count': 0,\n",
    "            'times_to_goal': [],\n",
    "            'times_to_fail': [],\n",
    "            'final_states': defaultdict(int),\n",
    "            'start_state': start_state,\n",
    "            'n_simulations': n_simulations,\n",
    "            'max_steps': max_steps\n",
    "        }\n",
    "        \n",
    "        for _ in range(n_simulations):\n",
    "            _, time_abs, final = self.simulate_trajectory(start_state, max_steps)\n",
    "            if final is None:\n",
    "                continue\n",
    "            \n",
    "            stats['final_states'][final] += 1\n",
    "            \n",
    "            if final in self.mc.absorbing_states:\n",
    "                typ = self.mc.absorbing_states[final]\n",
    "                if typ == 'GOAL':\n",
    "                    stats['goal_count'] += 1\n",
    "                    stats['times_to_goal'].append(time_abs)\n",
    "                elif typ == 'FAIL':\n",
    "                    stats['fail_count'] += 1\n",
    "                    stats['times_to_fail'].append(time_abs)\n",
    "            else:\n",
    "                stats['other_count'] += 1\n",
    "        \n",
    "        return stats\n",
    "\n",
    "# %% [markdown]\n",
    "# # PARTIE 4 : DÉFINITION DES GRILLES DE TEST\n",
    "\n",
    "# %%\n",
    "def get_test_grids():\n",
    "    \"\"\"Retourne les 3 grilles de test avec leurs configurations.\"\"\"\n",
    "    return [\n",
    "        {\n",
    "            'name': 'Facile',\n",
    "            'grid': Grid(5, 5, obstacles=[(2, 2)]),\n",
    "            'start': (0, 0),\n",
    "            'goal': (4, 4),\n",
    "            'desc': '5×5, 1 obstacle central'\n",
    "        },\n",
    "        {\n",
    "            'name': 'Moyenne',\n",
    "            'grid': Grid(8, 8, obstacles=[(2,2), (2,3), (3,2), (5,5), (5,6), (6,5)]),\n",
    "            'start': (0, 0),\n",
    "            'goal': (7, 7),\n",
    "            'desc': '8×8, 6 obstacles'\n",
    "        },\n",
    "        {\n",
    "            'name': 'Difficile',\n",
    "            'grid': Grid(10, 10,\n",
    "                        obstacles=([(i,5) for i in range(2,8)] + \n",
    "                                  [(5,j) for j in range(2,8)])),\n",
    "            'start': (0, 0),\n",
    "            'goal': (9, 9),\n",
    "            'desc': '10×10, croix centrale'\n",
    "        }\n",
    "    ]\n",
    "\n",
    "# %% [markdown]\n",
    "# ## 4.1 Visualisation des grilles\n",
    "\n",
    "# %%\n",
    "# Visualisation améliorée des grilles\n",
    "grids = get_test_grids()\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 6))\n",
    "fig.suptitle(\"Figure 1 : Grilles de test\", fontsize=16, fontweight='bold', y=1.02)\n",
    "\n",
    "# Définir une carte de couleurs personnalisée\n",
    "colors = ['white', 'black', 'red', 'green']\n",
    "cmap = plt.matplotlib.colors.ListedColormap(colors)\n",
    "bounds = [0, 1, 2, 3, 4]\n",
    "norm = plt.matplotlib.colors.BoundaryNorm(bounds, cmap.N)\n",
    "\n",
    "for idx, cfg in enumerate(grids):\n",
    "    ax = axes[idx]\n",
    "    grid = cfg['grid']\n",
    "    name = cfg['name']\n",
    "    desc = cfg['desc']\n",
    "    start = cfg['start']\n",
    "    goal = cfg['goal']\n",
    "    \n",
    "    # Créer une matrice pour la visualisation\n",
    "    viz = np.zeros((grid.height, grid.width))\n",
    "    \n",
    "    # Marquer les obstacles (1 = obstacle)\n",
    "    for y in range(grid.height):\n",
    "        for x in range(grid.width):\n",
    "            if not grid.is_free(x, y):\n",
    "                viz[y, x] = 1\n",
    "    \n",
    "    # Marquer start et goal avec des valeurs spéciales\n",
    "    sx, sy = start\n",
    "    gx, gy = goal\n",
    "    viz[sy, sx] = 2  # start\n",
    "    viz[gy, gx] = 3  # goal\n",
    "    \n",
    "    # Afficher la grille\n",
    "    im = ax.imshow(viz, cmap=cmap, norm=norm, origin='upper', \n",
    "                  interpolation='none', aspect='equal')\n",
    "    \n",
    "    # Ajouter une grille pour mieux voir les cellules\n",
    "    ax.set_xticks(np.arange(-0.5, grid.width, 1), minor=True)\n",
    "    ax.set_yticks(np.arange(-0.5, grid.height, 1), minor=True)\n",
    "    ax.grid(which='minor', color='gray', linestyle='-', linewidth=1)\n",
    "    ax.tick_params(which='minor', size=0)\n",
    "    \n",
    "    # Configurer les axes\n",
    "    ax.set_xticks(range(grid.width))\n",
    "    ax.set_yticks(range(grid.height))\n",
    "    ax.set_xticklabels(range(grid.width))\n",
    "    ax.set_yticklabels(range(grid.height))\n",
    "    ax.tick_params(axis='both', which='major', labelsize=8)\n",
    "    \n",
    "    # Ajouter des annotations claires pour S et G\n",
    "    ax.text(sx, sy, 'S', ha='center', va='center', \n",
    "            fontweight='bold', fontsize=16, color='white',\n",
    "            bbox=dict(boxstyle='circle', facecolor='red', edgecolor='white', alpha=0.8))\n",
    "    \n",
    "    ax.text(gx, gy, 'G', ha='center', va='center', \n",
    "            fontweight='bold', fontsize=16, color='white',\n",
    "            bbox=dict(boxstyle='circle', facecolor='green', edgecolor='white', alpha=0.8))\n",
    "    \n",
    "    ax.set_title(f\"Grille {name}\\n{desc}\", fontsize=12, fontweight='bold')\n",
    "    ax.set_xlabel('X', fontsize=10)\n",
    "    ax.set_ylabel('Y', fontsize=10)\n",
    "\n",
    "# Ajouter une légende globale\n",
    "legend_elements = [\n",
    "    Patch(facecolor='white', edgecolor='gray', label='Cellule libre'),\n",
    "    Patch(facecolor='black', edgecolor='gray', label='Obstacle'),\n",
    "    Patch(facecolor='red', edgecolor='white', label='Start (S)'),\n",
    "    Patch(facecolor='green', edgecolor='white', label='Goal (G)')\n",
    "]\n",
    "fig.legend(handles=legend_elements, loc='lower center', \n",
    "          bbox_to_anchor=(0.5, -0.05), ncol=4, fontsize=11)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Afficher aussi les coordonnées pour vérification\n",
    "print(\"\\nCoordonnées des points importants :\")\n",
    "for cfg in grids:\n",
    "    print(f\"Grille {cfg['name']}: Start {cfg['start']} → Goal {cfg['goal']}\")\n",
    "\n",
    "# %% [markdown]\n",
    "# # PARTIE 5 : EXPÉRIENCES\n",
    "\n",
    "# %% [markdown]\n",
    "# ## 5.1 Expérience E.1 - Comparaison UCS vs Greedy vs A*\n",
    "\n",
    "# %%\n",
    "def experiment_1_compare_algorithms():\n",
    "    \"\"\"E.1 : Comparer UCS, Greedy et A* sur les 3 grilles.\"\"\"\n",
    "    print(\"=\"*70)\n",
    "    print(\"EXPÉRIENCE E.1 : COMPARAISON UCS / GREEDY / A*\")\n",
    "    print(\"=\"*70)\n",
    "    \n",
    "    grids = get_test_grids()\n",
    "    results = {}\n",
    "    \n",
    "    # Tableau des résultats\n",
    "    print(\"\\nRésultats détaillés :\")\n",
    "    print(\"-\" * 90)\n",
    "    print(f\"{'Grille':<12} {'Algo':<8} {'Coût':>6} {'Noeuds':>10} {'OPEN max':>10} {'Temps (ms)':>12}\")\n",
    "    print(\"-\" * 90)\n",
    "    \n",
    "    for cfg in grids:\n",
    "        searcher = AStar(cfg['grid'], heuristic='manhattan')\n",
    "        results[cfg['name']] = {}\n",
    "        \n",
    "        for algo in ['ucs', 'greedy', 'astar']:\n",
    "            r = searcher.search(cfg['start'], cfg['goal'], algorithm=algo)\n",
    "            results[cfg['name']][algo] = r\n",
    "            \n",
    "            print(f\"{cfg['name']:<12} {algo:<8} {r['cost']:>6} \"\n",
    "                  f\"{r['nodes_expanded']:>10} {r['max_open_size']:>10} \"\n",
    "                  f\"{r['time_sec']*1000:>11.3f}\")\n",
    "    \n",
    "    # Graphique\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "    fig.suptitle(\"Figure 2 : Comparaison UCS / Greedy / A*\", fontsize=14, y=1.02)\n",
    "    \n",
    "    algos = ['ucs', 'greedy', 'astar']\n",
    "    colors = ['#2196F3', '#F44336', '#4CAF50']\n",
    "    x = np.arange(len(algos))\n",
    "    \n",
    "    for ax, cfg in zip(axes, grids):\n",
    "        res = results[cfg['name']]\n",
    "        costs = [res[a]['cost'] for a in algos]\n",
    "        nodes = [res[a]['nodes_expanded'] for a in algos]\n",
    "        \n",
    "        bars1 = ax.bar(x - 0.2, costs, 0.35, label='Coût', color=colors, alpha=0.85)\n",
    "        bars2 = ax.bar(x + 0.2, nodes, 0.35, label='Noeuds développés', \n",
    "                      color=colors, alpha=0.4, hatch='//')\n",
    "        \n",
    "        for bar, val in zip(bars1, costs):\n",
    "            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.3,\n",
    "                   str(val), ha='center', va='bottom', fontsize=9, fontweight='bold')\n",
    "        for bar, val in zip(bars2, nodes):\n",
    "            ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.3,\n",
    "                   str(val), ha='center', va='bottom', fontsize=9)\n",
    "        \n",
    "        ax.set_title(f\"Grille {cfg['name']}\\n({cfg['desc']})\", fontsize=11)\n",
    "        ax.set_xticks(x)\n",
    "        ax.set_xticklabels(['UCS', 'Greedy', 'A*'], fontsize=11)\n",
    "        ax.set_ylabel(\"Valeur\")\n",
    "        ax.legend(fontsize=9)\n",
    "        ax.grid(True, alpha=0.3, axis='y')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Exécution E.1\n",
    "results_e1 = experiment_1_compare_algorithms()\n",
    "\n",
    "# %% [markdown]\n",
    "# ## 5.2 Expérience E.2 - Impact de l'incertitude ε (VERSION CORRIGÉE)\n",
    "\n",
    "# %%\n",
    "def experiment_2_vary_epsilon():\n",
    "    \"\"\"E.2 : Varier ε et observer l'impact sur P(GOAL) - VERSION CORRIGÉE\"\"\"\n",
    "    print(\"\\n\" + \"=\"*70)\n",
    "    print(\"EXPÉRIENCE E.2 : IMPACT DE L'INCERTITUDE ε\")\n",
    "    print(\"=\"*70)\n",
    "    \n",
    "    # Grille facile\n",
    "    cfg = get_test_grids()[0]\n",
    "    grid, start, goal = cfg['grid'], cfg['start'], cfg['goal']\n",
    "    epsilons = [0.0, 0.1, 0.2, 0.3]\n",
    "    n_steps = 30\n",
    "    N_SIM = 2000\n",
    "    \n",
    "    # Planification A*\n",
    "    searcher = AStar(grid, heuristic='manhattan')\n",
    "    result = searcher.search(start, goal, algorithm='astar')\n",
    "    policy = searcher.extract_policy(result['path'])\n",
    "    \n",
    "    print(f\"\\nChemin A* (coût = {result['cost']}) : {result['path']}\")\n",
    "    print(f\"Longueur du chemin : {len(result['path'])} étapes\")\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    for eps in epsilons:\n",
    "        # Construction de la chaîne\n",
    "        absorbing = {goal: 'GOAL', (-1,-1): 'FAIL'}\n",
    "        all_states = set(result['path']) | {(-1,-1)}\n",
    "        mc = MarkovChain(all_states, absorbing)\n",
    "        mc.build_from_policy(policy, grid, epsilon=eps)\n",
    "        \n",
    "        # Évolution théorique\n",
    "        evol = mc.get_distribution_evolution(start, n_steps)\n",
    "        goal_idx = mc.state_to_idx[goal]\n",
    "        p_goal_evol = [d[goal_idx] for d in evol]\n",
    "        \n",
    "        # Analyse d'absorption\n",
    "        ab = mc.absorption_analysis()\n",
    "        if ab and start in mc.state_to_idx:\n",
    "            i0 = mc.state_to_idx[start]\n",
    "            if i0 in ab['trans_indices']:\n",
    "                loc = ab['trans_indices'].index(i0)\n",
    "                # Trouver l'indice de GOAL dans les états absorbants\n",
    "                goal_ai = None\n",
    "                for j, ai in enumerate(ab['abs_indices']):\n",
    "                    if mc.idx_to_state[ai] == goal:\n",
    "                        goal_ai = j\n",
    "                        break\n",
    "                if goal_ai is not None:\n",
    "                    p_goal_abs = ab['B'][loc, goal_ai]\n",
    "                    t_abs = ab['t'][loc]\n",
    "                else:\n",
    "                    p_goal_abs, t_abs = 0.0, float('inf')\n",
    "            else:\n",
    "                p_goal_abs, t_abs = 1.0, 0.0\n",
    "        else:\n",
    "            p_goal_abs, t_abs = None, None\n",
    "        \n",
    "        # Simulation Monte-Carlo\n",
    "        sim = MarkovSimulation(mc)\n",
    "        stats = sim.run_simulations(start, n_simulations=N_SIM, max_steps=100)\n",
    "        p_goal_emp = stats['goal_count'] / N_SIM\n",
    "        t_emp = np.mean(stats['times_to_goal']) if stats['times_to_goal'] else None\n",
    "        \n",
    "        results.append({\n",
    "            'epsilon': eps,\n",
    "            'evol': p_goal_evol,\n",
    "            'p_goal_abs': p_goal_abs,\n",
    "            'p_goal_emp': p_goal_emp,\n",
    "            't_abs': t_abs,\n",
    "            't_emp': t_emp\n",
    "        })\n",
    "        \n",
    "        print(f\"\\nε = {eps:.1f}\")\n",
    "        print(f\"  P(GOAL) théorique (n={n_steps}) : {p_goal_evol[-1]:.4f}\")\n",
    "        if p_goal_abs is not None:\n",
    "            print(f\"  P(GOAL) absorption        : {p_goal_abs:.4f}\")\n",
    "            print(f\"  E[T] théorique            : {t_abs:.2f}\")\n",
    "        print(f\"  P(GOAL) empirique (N={N_SIM}) : {p_goal_emp:.4f}\")\n",
    "        if t_emp:\n",
    "            print(f\"  E[T] empirique             : {t_emp:.2f}\")\n",
    "        print(f\"  Écart théorie/empirique    : {abs(p_goal_abs - p_goal_emp):.4f}\")\n",
    "    \n",
    "    # Graphiques\n",
    "    fig = plt.figure(figsize=(14, 10))\n",
    "    gs = gridspec.GridSpec(2, 2, figure=fig, hspace=0.3, wspace=0.3)\n",
    "    \n",
    "    # 1. Courbes d'évolution\n",
    "    ax1 = fig.add_subplot(gs[0, :])\n",
    "    colors = ['blue', 'green', 'orange', 'red']\n",
    "    for i, res in enumerate(results):\n",
    "        ax1.plot(range(1, n_steps+1), res['evol'], \n",
    "                color=colors[i], linewidth=2.5,\n",
    "                label=f\"ε = {res['epsilon']:.1f}\")\n",
    "    ax1.set_xlabel(\"Pas n\", fontsize=12)\n",
    "    ax1.set_ylabel(\"P(être dans GOAL)\", fontsize=12)\n",
    "    ax1.set_title(\"Évolution de P(GOAL) = π(n)[GOAL]\", fontsize=14, fontweight='bold')\n",
    "    ax1.legend(fontsize=11, loc='lower right')\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    ax1.set_ylim(-0.05, 1.05)\n",
    "    ax1.axhline(y=1.0, color='gray', linestyle='--', alpha=0.5)\n",
    "    \n",
    "    # 2. Barres de comparaison\n",
    "    ax2 = fig.add_subplot(gs[1, 0])\n",
    "    eps_labels = [f\"ε={r['epsilon']:.1f}\" for r in results]\n",
    "    p_abs = [r['p_goal_abs'] if r['p_goal_abs'] is not None else 0 for r in results]\n",
    "    p_emp = [r['p_goal_emp'] for r in results]\n",
    "    xi = np.arange(len(results))\n",
    "    width = 0.35\n",
    "    \n",
    "    bars1 = ax2.bar(xi - width/2, p_abs, width, label='Théorique (absorption)', \n",
    "                   color='steelblue', alpha=0.8, edgecolor='navy')\n",
    "    bars2 = ax2.bar(xi + width/2, p_emp, width, label=f'Empirique (N={N_SIM})', \n",
    "                   color='tomato', alpha=0.8, edgecolor='darkred')\n",
    "    \n",
    "    # Ajouter les valeurs sur les barres\n",
    "    for bar in bars1:\n",
    "        height = bar.get_height()\n",
    "        ax2.text(bar.get_x() + bar.get_width()/2., height + 0.02,\n",
    "                f'{height:.3f}', ha='center', va='bottom', fontsize=9)\n",
    "    for bar in bars2:\n",
    "        height = bar.get_height()\n",
    "        ax2.text(bar.get_x() + bar.get_width()/2., height + 0.02,\n",
    "                f'{height:.3f}', ha='center', va='bottom', fontsize=9)\n",
    "    \n",
    "    ax2.set_xticks(xi)\n",
    "    ax2.set_xticklabels(eps_labels, fontsize=11)\n",
    "    ax2.set_ylabel(\"P(atteindre GOAL)\", fontsize=12)\n",
    "    ax2.set_title(\"Probabilité de succès\", fontsize=13, fontweight='bold')\n",
    "    ax2.legend(fontsize=10)\n",
    "    ax2.grid(True, alpha=0.3, axis='y')\n",
    "    ax2.set_ylim(0, 1.2)\n",
    "    \n",
    "    # 3. Temps moyen\n",
    "    ax3 = fig.add_subplot(gs[1, 1])\n",
    "    t_abs_vals = [r['t_abs'] if r['t_abs'] is not None else 0 for r in results]\n",
    "    t_emp_vals = [r['t_emp'] if r['t_emp'] is not None else 0 for r in results]\n",
    "    \n",
    "    bars3 = ax3.bar(xi - width/2, t_abs_vals, width, label='E[T] théorique',\n",
    "                   color='steelblue', alpha=0.8, edgecolor='navy')\n",
    "    bars4 = ax3.bar(xi + width/2, t_emp_vals, width, label='E[T] empirique',\n",
    "                   color='tomato', alpha=0.8, edgecolor='darkred')\n",
    "    \n",
    "    for bar in bars3:\n",
    "        height = bar.get_height()\n",
    "        ax3.text(bar.get_x() + bar.get_width()/2., height + 0.2,\n",
    "                f'{height:.1f}', ha='center', va='bottom', fontsize=9)\n",
    "    for bar in bars4:\n",
    "        height = bar.get_height()\n",
    "        ax3.text(bar.get_x() + bar.get_width()/2., height + 0.2,\n",
    "                f'{height:.1f}', ha='center', va='bottom', fontsize=9)\n",
    "    \n",
    "    ax3.set_xticks(xi)\n",
    "    ax3.set_xticklabels(eps_labels, fontsize=11)\n",
    "    ax3.set_ylabel(\"Temps moyen (étapes)\", fontsize=12)\n",
    "    ax3.set_title(\"Temps moyen avant absorption\", fontsize=13, fontweight='bold')\n",
    "    ax3.legend(fontsize=10)\n",
    "    ax3.grid(True, alpha=0.3, axis='y')\n",
    "    \n",
    "    plt.suptitle(\"Figure 3 : Impact de l'incertitude ε sur P(GOAL)\", \n",
    "                fontsize=16, fontweight='bold', y=1.02)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Exécution E.2 (une seule fois - version corrigée)\n",
    "results_e2 = experiment_2_vary_epsilon()\n",
    "\n",
    "# %% [markdown]\n",
    "# ## 5.3 Expérience E.3 - Comparaison des heuristiques\n",
    "\n",
    "# %%\n",
    "def experiment_3_compare_heuristics():\n",
    "    \"\"\"E.3 : Comparer h=0 vs Manhattan.\"\"\"\n",
    "    print(\"\\n\" + \"=\"*70)\n",
    "    print(\"EXPÉRIENCE E.3 : COMPARAISON HEURISTIQUES h=0 vs Manhattan\")\n",
    "    print(\"=\"*70)\n",
    "    \n",
    "    grids = get_test_grids()\n",
    "    \n",
    "    print(\"\\n\" + \"-\"*80)\n",
    "    print(f\"{'Grille':<15} {'Heuristique':<12} {'Coût':>6} {'Noeuds':>10} {'OPEN max':>12} {'Temps (ms)':>12}\")\n",
    "    print(\"-\"*80)\n",
    "    \n",
    "    results = {}\n",
    "    \n",
    "    for cfg in grids:\n",
    "        results[cfg['name']] = {}\n",
    "        for h_name in ['zero', 'manhattan']:\n",
    "            searcher = AStar(cfg['grid'], heuristic=h_name)\n",
    "            r = searcher.search(cfg['start'], cfg['goal'], algorithm='astar')\n",
    "            results[cfg['name']][h_name] = r\n",
    "            \n",
    "            label = \"h = 0\" if h_name == 'zero' else \"Manhattan\"\n",
    "            print(f\"{cfg['name']:<15} {label:<12} {r['cost']:>6} \"\n",
    "                  f\"{r['nodes_expanded']:>10} {r['max_open_size']:>12} \"\n",
    "                  f\"{r['time_sec']*1000:>11.3f}\")\n",
    "    \n",
    "    # Graphique\n",
    "    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "    fig.suptitle(\"Figure 4 : Comparaison heuristiques h=0 vs Manhattan\", fontsize=14, y=1.02)\n",
    "    \n",
    "    for ax, cfg in zip(axes, grids):\n",
    "        res = results[cfg['name']]\n",
    "        nodes = [res['zero']['nodes_expanded'], res['manhattan']['nodes_expanded']]\n",
    "        open_max = [res['zero']['max_open_size'], res['manhattan']['max_open_size']]\n",
    "        xi = np.arange(2)\n",
    "        \n",
    "        bars1 = ax.bar(xi - 0.2, nodes, 0.35, label='Noeuds développés',\n",
    "                      color=['#FF9800', '#9C27B0'], alpha=0.85)\n",
    "        bars2 = ax.bar(xi + 0.2, open_max, 0.35, label='OPEN max',\n",
    "                      color=['#FF9800', '#9C27B0'], alpha=0.4, hatch='//')\n",
    "        \n",
    "        for i, (n, o) in enumerate(zip(nodes, open_max)):\n",
    "            ax.text(i-0.2, n+0.3, str(n), ha='center', fontsize=9, fontweight='bold')\n",
    "            ax.text(i+0.2, o+0.3, str(o), ha='center', fontsize=9)\n",
    "        \n",
    "        ax.set_title(f\"Grille {cfg['name']}\\n({cfg['desc']})\", fontsize=11)\n",
    "        ax.set_xticks(xi)\n",
    "        ax.set_xticklabels(['h = 0', 'Manhattan'], fontsize=11)\n",
    "        ax.set_ylabel(\"Nombre\")\n",
    "        ax.legend(fontsize=9)\n",
    "        ax.grid(True, alpha=0.3, axis='y')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Exécution E.3\n",
    "results_e3 = experiment_3_compare_heuristics()\n",
    "\n",
    "# %% [markdown]\n",
    "# ## 5.4 Expérience E.4 (Option) - Weighted A*\n",
    "\n",
    "# %%\n",
    "def experiment_4_weighted_astar():\n",
    "    \"\"\"E.4 (Option) : Weighted A* - compromis vitesse/optimalité.\"\"\"\n",
    "    print(\"\\n\" + \"=\"*70)\n",
    "    print(\"EXPÉRIENCE E.4 (OPTION) : WEIGHTED A*\")\n",
    "    print(\"=\"*70)\n",
    "    \n",
    "    # Grille difficile\n",
    "    cfg = get_test_grids()[2]\n",
    "    grid, start, goal = cfg['grid'], cfg['start'], cfg['goal']\n",
    "    weights = [1.0, 1.5, 2.0, 2.5, 3.0, 4.0, 5.0]\n",
    "    \n",
    "    searcher = AStar(grid, heuristic='manhattan')\n",
    "    r_opt = searcher.search(start, goal, algorithm='astar', weight=1.0)\n",
    "    c_opt = r_opt['cost']\n",
    "    \n",
    "    print(f\"\\nGrille {cfg['name']} | Coût optimal = {c_opt}\")\n",
    "    print(\"\\n\" + \"-\"*65)\n",
    "    print(f\"{'w':>6} {'Coût':>8} {'Noeuds':>10} {'OPEN max':>12} {'Sous-opt (%)':>14} {'Speedup':>10}\")\n",
    "    print(\"-\"*65)\n",
    "    \n",
    "    results = []\n",
    "    for w in weights:\n",
    "        r = searcher.search(start, goal, algorithm='astar', weight=w)\n",
    "        sous_opt = (r['cost'] - c_opt) / c_opt * 100\n",
    "        speedup = r_opt['nodes_expanded'] / max(r['nodes_expanded'], 1)\n",
    "        \n",
    "        results.append({\n",
    "            'w': w,\n",
    "            'cost': r['cost'],\n",
    "            'nodes': r['nodes_expanded'],\n",
    "            'open': r['max_open_size'],\n",
    "            'sous_opt': sous_opt,\n",
    "            'speedup': speedup\n",
    "        })\n",
    "        \n",
    "        print(f\"{w:6.1f} {r['cost']:8d} {r['nodes_expanded']:10d} \"\n",
    "              f\"{r['max_open_size']:12d} {sous_opt:13.2f}% {speedup:10.2f}x\")\n",
    "    \n",
    "    # Graphiques\n",
    "    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "    fig.suptitle(\"Figure 5 : Weighted A* - Compromis vitesse/optimalité\", fontsize=14, y=1.02)\n",
    "    \n",
    "    ws = [r['w'] for r in results]\n",
    "    nodes = [r['nodes'] for r in results]\n",
    "    sous = [r['sous_opt'] for r in results]\n",
    "    speeds = [r['speedup'] for r in results]\n",
    "    \n",
    "    # Noeuds développés\n",
    "    ax1.plot(ws, nodes, 'o-', color='steelblue', linewidth=2, markersize=8)\n",
    "    for w, n in zip(ws, nodes):\n",
    "        ax1.annotate(str(n), (w, n), textcoords=\"offset points\", xytext=(5,5), fontsize=9)\n",
    "    ax1.set_xlabel(\"Poids w\")\n",
    "    ax1.set_ylabel(\"Noeuds développés\")\n",
    "    ax1.set_title(\"Réduction des noeuds développés\")\n",
    "    ax1.grid(True, alpha=0.3)\n",
    "    \n",
    "    # Sous-optimalité et speedup\n",
    "    color1, color2 = '#E91E63', '#009688'\n",
    "    ln1 = ax2.plot(ws, sous, 's-', color=color1, linewidth=2, markersize=8, \n",
    "                  label='Sous-optimalité (%)')\n",
    "    ax2b = ax2.twinx()\n",
    "    ln2 = ax2b.plot(ws, speeds, 'D-', color=color2, linewidth=2, markersize=8, \n",
    "                   label='Speedup (x)')\n",
    "    ax2.set_xlabel(\"Poids w\")\n",
    "    ax2.set_ylabel(\"Sous-optimalité (%)\", color=color1)\n",
    "    ax2b.set_ylabel(\"Speedup (x)\", color=color2)\n",
    "    ax2.set_title(\"Sous-optimalité et Speedup\")\n",
    "    lines = ln1 + ln2\n",
    "    labels = [l.get_label() for l in lines]\n",
    "    ax2.legend(lines, labels, loc='center right')\n",
    "    ax2.grid(True, alpha=0.3)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Exécution E.4\n",
    "results_e4 = experiment_4_weighted_astar()\n",
    "\n",
    "# %% [markdown]\n",
    "# # PARTIE 6 : ANALYSE APPROFONDIE D'UNE CHAÎNE DE MARKOV\n",
    "\n",
    "# %%\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"ANALYSE APPROFONDIE : CHAÎNE DE MARKOV (ε = 0.2)\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "# Configuration\n",
    "cfg = get_test_grids()[0]\n",
    "grid, start, goal = cfg['grid'], cfg['start'], cfg['goal']\n",
    "epsilon = 0.2\n",
    "\n",
    "# Planification\n",
    "searcher = AStar(grid, heuristic='manhattan')\n",
    "result = searcher.search(start, goal, algorithm='astar')\n",
    "policy = searcher.extract_policy(result['path'])\n",
    "\n",
    "print(f\"\\nChemin planifié : {result['path']}\")\n",
    "print(f\"Longueur du chemin : {result['cost']}\")\n",
    "\n",
    "# Construction de la chaîne\n",
    "absorbing = {goal: 'GOAL', (-1,-1): 'FAIL'}\n",
    "all_states = set(result['path']) | {(-1,-1)}\n",
    "mc = MarkovChain(all_states, absorbing)\n",
    "mc.build_from_policy(policy, grid, epsilon=epsilon)\n",
    "\n",
    "print(f\"\\n=== Analyse de la matrice P ===\")\n",
    "print(f\"Taille de P : {mc.n} × {mc.n}\")\n",
    "print(f\"P est stochastique : {mc.is_stochastic()}\")\n",
    "\n",
    "# Affichage de P\n",
    "print(\"\\nMatrice de transition P (lignes = état courant, colonnes = état suivant) :\")\n",
    "print(\"-\" * 60)\n",
    "print(f\"{'État\\\\vers':<10}\", end='')\n",
    "for state in mc.states:\n",
    "    print(f\"{str(state):<12}\", end='')\n",
    "print()\n",
    "for i, state_i in enumerate(mc.states):\n",
    "    print(f\"{str(state_i):<10}\", end='')\n",
    "    for j in range(mc.n):\n",
    "        print(f\"{mc.P[i, j]:<12.3f}\", end='')\n",
    "    print()\n",
    "\n",
    "# Analyse des classes\n",
    "print(\"\\n=== Analyse des classes de communication ===\")\n",
    "classes = mc.analyze_classes()\n",
    "for k, cls in enumerate(classes):\n",
    "    print(f\"Classe {k+1} [{cls['type']}] : {cls['etats']}\")\n",
    "\n",
    "# Analyse de périodicité\n",
    "print(\"\\n=== Analyse de périodicité ===\")\n",
    "periodicite = mc.analyze_periodicity()\n",
    "for p in periodicite:\n",
    "    print(f\"États {p['etats']} : période = {p['periode']} \" + \n",
    "          f\"({'périodique' if p['est_periodique'] else 'apériodique'})\")\n",
    "\n",
    "# Analyse d'absorption\n",
    "print(\"\\n=== Analyse d'absorption ===\")\n",
    "ab = mc.absorption_analysis()\n",
    "if ab:\n",
    "    print(f\"Matrice fondamentale N (dim {ab['N'].shape[0]}×{ab['N'].shape[0]}) :\")\n",
    "    print(ab['N'])\n",
    "    print(f\"\\nProbabilités d'absorption B (depuis {start}) :\")\n",
    "    i0 = ab['trans_indices'].index(mc.state_to_idx[start])\n",
    "    for j, ai in enumerate(ab['abs_indices']):\n",
    "        state = mc.idx_to_state[ai]\n",
    "        typ = mc.absorbing_states[state]\n",
    "        print(f\"  P(→ {state} [{typ}]) = {ab['B'][i0, j]:.6f}\")\n",
    "    print(f\"\\nTemps moyen avant absorption E[T] = {ab['t'][i0]:.4f} étapes\")\n",
    "\n",
    "# %% [markdown]\n",
    "# # PARTIE 7 : VALIDATION SIMULATION VS THÉORIE\n",
    "\n",
    "# %%\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"VALIDATION : SIMULATION MONTE-CARLO VS THÉORIE\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "# Simulation\n",
    "sim = MarkovSimulation(mc)\n",
    "N_SIM = 5000\n",
    "stats = sim.run_simulations(start, n_simulations=N_SIM, max_steps=100)\n",
    "\n",
    "# Analyse des simulations\n",
    "p_goal_emp = stats['goal_count'] / N_SIM\n",
    "p_fail_emp = stats['fail_count'] / N_SIM\n",
    "p_other_emp = stats['other_count'] / N_SIM\n",
    "t_goal_emp = np.mean(stats['times_to_goal']) if stats['times_to_goal'] else None\n",
    "\n",
    "print(f\"\\nRésultats de la simulation (N = {N_SIM}) :\")\n",
    "print(f\"  P(atteindre GOAL) = {p_goal_emp:.4f}\")\n",
    "print(f\"  P(atteindre FAIL) = {p_fail_emp:.4f}\")\n",
    "print(f\"  P(non absorbé)    = {p_other_emp:.4f}\")\n",
    "if t_goal_emp:\n",
    "    print(f\"  Temps moyen vers GOAL = {t_goal_emp:.2f}\")\n",
    "\n",
    "# Comparaison avec la théorie\n",
    "if ab:\n",
    "    i0 = ab['trans_indices'].index(mc.state_to_idx[start])\n",
    "    goal_ai = next((j for j, ai in enumerate(ab['abs_indices']) \n",
    "                   if mc.idx_to_state[ai] == goal), None)\n",
    "    if goal_ai is not None:\n",
    "        p_goal_th = ab['B'][i0, goal_ai]\n",
    "        t_th = ab['t'][i0]\n",
    "        \n",
    "        print(\"\\nComparaison théorie vs simulation :\")\n",
    "        print(f\"  P(GOAL) théorique : {p_goal_th:.4f} | empirique : {p_goal_emp:.4f} | \"\n",
    "              f\"écart : {abs(p_goal_th - p_goal_emp):.4f}\")\n",
    "        print(f\"  E[T] théorique    : {t_th:.2f} | empirique : {t_goal_emp:.2f} | \"\n",
    "              f\"écart : {abs(t_th - t_goal_emp):.2f}\")\n",
    "\n",
    "# Visualisation des trajectoires\n",
    "print(\"\\nExemples de trajectoires :\")\n",
    "for i in range(5):\n",
    "    traj, time_abs, final = sim.simulate_trajectory(start, max_steps=20)\n",
    "    final_type = mc.absorbing_states.get(final, 'non absorbé')\n",
    "    print(f\"  Trajectoire {i+1} : {traj[:5]}... → {final} [{final_type}] (en {time_abs} étapes)\")\n",
    "\n",
    "# %% [markdown]\n",
    "# # PARTIE 8 : SYNTHÈSE DES RÉSULTATS\n",
    "\n",
    "# %%\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"SYNTHÈSE : IMPACT DE L'INCERTITUDE ε\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "print(\"\\n\" + \"-\"*85)\n",
    "print(f\"{'ε':>8} {'P(GOAL) P^n':>15} {'P(GOAL) abs':>15} {'P(GOAL) emp':>15} {'E[T] abs':>12} {'E[T] emp':>12}\")\n",
    "print(\"-\"*85)\n",
    "\n",
    "for res in results_e2:\n",
    "    print(f\"{res['epsilon']:8.1f} \"\n",
    "          f\"{res['evol'][-1]:15.4f} \"\n",
    "          f\"{res['p_goal_abs'] if res['p_goal_abs'] is not None else 0:15.4f} \"\n",
    "          f\"{res['p_goal_emp']:15.4f} \"\n",
    "          f\"{res['t_abs'] if res['t_abs'] is not None else 0:12.2f} \"\n",
    "          f\"{res['t_emp'] if res['t_emp'] is not None else 0:12.2f}\")\n",
    "\n",
    "# %%\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "fig.suptitle(\"Figure 6 : Synthèse - Impact de l'incertitude\", fontsize=14, y=1.02)\n",
    "\n",
    "epsilons = [r['epsilon'] for r in results_e2]\n",
    "p_goals = [r['p_goal_abs'] if r['p_goal_abs'] is not None else 0 for r in results_e2]\n",
    "t_vals = [r['t_abs'] if r['t_abs'] is not None else 0 for r in results_e2]\n",
    "\n",
    "ax1.plot(epsilons, p_goals, 'o-', color='darkgreen', linewidth=2, markersize=8, label='P(GOAL)')\n",
    "for i, (eps, p) in enumerate(zip(epsilons, p_goals)):\n",
    "    ax1.annotate(f'{p:.3f}', (eps, p), textcoords=\"offset points\", xytext=(0,10), ha='center', fontsize=9)\n",
    "ax1.set_xlabel(\"Taux d'incertitude ε\")\n",
    "ax1.set_ylabel(\"P(atteindre GOAL)\")\n",
    "ax1.set_title(\"Probabilité de succès vs incertitude\")\n",
    "ax1.grid(True, alpha=0.3)\n",
    "ax1.set_ylim(0, 1.05)\n",
    "ax1.legend()\n",
    "\n",
    "ax2.plot(epsilons, t_vals, 's-', color='darkorange', linewidth=2, markersize=8, label='E[T]')\n",
    "for i, (eps, t) in enumerate(zip(epsilons, t_vals)):\n",
    "    ax2.annotate(f'{t:.1f}', (eps, t), textcoords=\"offset points\", xytext=(0,10), ha='center', fontsize=9)\n",
    "ax2.set_xlabel(\"Taux d'incertitude ε\")\n",
    "ax2.set_ylabel(\"Temps moyen avant absorption\")\n",
    "ax2.set_title(\"Temps moyen de succès vs incertitude\")\n",
    "ax2.grid(True, alpha=0.3)\n",
    "ax2.legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# %% [markdown]\n",
    "# ## Vérification de la cohérence des résultats\n",
    "\n",
    "# %%\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"📊 VÉRIFICATION DE COHÉRENCE DES RÉSULTATS\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "print(\"\\nVérification que P(GOAL) diminue quand ε augmente :\")\n",
    "coherent = True\n",
    "for i in range(1, len(results_e2)):\n",
    "    if results_e2[i]['p_goal_abs'] < results_e2[i-1]['p_goal_abs']:\n",
    "        print(f\"  ✓ ε={results_e2[i]['epsilon']:.1f} < ε={results_e2[i-1]['epsilon']:.1f} : P(GOAL) diminue\")\n",
    "    else:\n",
    "        print(f\"  ✗ Incohérence : ε={results_e2[i]['epsilon']:.1f} devrait être < {results_e2[i-1]['p_goal_abs']:.4f}\")\n",
    "        coherent = False\n",
    "\n",
    "print(\"\\nVérification que E[T] augmente quand ε augmente :\")\n",
    "for i in range(1, len(results_e2)):\n",
    "    if results_e2[i]['t_abs'] > results_e2[i-1]['t_abs']:\n",
    "        print(f\"  ✓ ε={results_e2[i]['epsilon']:.1f} > ε={results_e2[i-1]['epsilon']:.1f} : E[T] augmente\")\n",
    "    else:\n",
    "        print(f\"  ✗ Incohérence : E[T] devrait augmenter\")\n",
    "        coherent = False\n",
    "\n",
    "if coherent:\n",
    "    print(\"\\n✅ Tous les résultats sont cohérents !\")\n",
    "else:\n",
    "    print(\"\\n⚠️ Des incohérences ont été détectées.\")\n",
    "\n",
    "# %% [markdown]\n",
    "\n",
    "\n",
    "# %%\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"🎉 NOTEBOOK EXÉCUTÉ AVEC SUCCÈS\")\n",
    "print(\"=\"*70)"
