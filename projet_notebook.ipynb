 temps discret\u001b[39m\u001b[38;5;130;01m\\\"\u001b[39;00m\u001b[38;5;130;01m\\\"\u001b[39;00m\u001b[38;5;130;01m\\\"\u001b[39;00m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    339\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m    \u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    340\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m    def __init__(self, states, absorbing_states=None):\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    341\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m        self.states = list(states)\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    342\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m        self.state_to_idx = \u001b[39m\u001b[33m{\u001b[39m\u001b[33mstate: i for i, state in enumerate(self.states)}\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    343\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m        self.idx_to_state = \u001b[39m\u001b[33m{\u001b[39m\u001b[33mi: state for i, state in enumerate(self.states)}\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    344\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m        self.n = len(states)\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    345\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m        self.P = np.zeros((self.n, self.n))\u001b[39m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    346\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m        self.absorbing_states = absorbing_states if absorbing_states else \u001b[39m\u001b[38;5;132;01m{}\u001b[39;00m\u001b[38;5;130;01m\\n\u001b[39;00m\u001b[33m\"\u001b[39m,\n\u001b[32m    347\u001b[39m     \u001b[33m\"\u001b[39m\u001b[33m        self.absorbing_indices = \u001b[39m\u001b[33m{\u001b[39m\u001b[33mself.state_to_idx[s] for s in absorbing_states.keys() if s in self.state_to_idx}\u001b[39m\u0